# ============================================================================
# Copy this file to ".env" and fill in the values. Never commit the real .env.
# ============================================================================

# Port the server listens on (most hosts inject this automatically).
PORT=8000

# Always "production" for a real deployment.
NODE_ENV=production

# --- Database -------------------------------------------------------------
# PostgreSQL connection string.
#  - With docker-compose (DB in the same network): leave the compose default and
#    set DATABASE_SSL=false.
#  - With a managed DB (Render/Neon/Railway/Supabase): paste their URL and leave
#    DATABASE_SSL unset (SSL is auto-enabled for remote hosts).
DATABASE_URL=postgres://quiz:quizpass@db:5432/quiz
DATABASE_SSL=false

# --- Auth -----------------------------------------------------------------
# REQUIRED in production. Use a long random string, e.g. generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- Optional: AI quiz generation / assistant -----------------------------
# Leave empty to disable the AI features (the rest of the app still works).
# GROQ_API_KEY powers AI question generation and the analytics chat assistant
# (free tier at console.groq.com).
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Optional: Sesli soru (voice question) özelliği ------------------------
# ElevenLabs API anahtarı — sadece "Text to Speech" scope'u yeterli.
# Boş bırakılırsa sesli soru özelliği devre dışı kalır, uygulamanın geri
# kalanı normal çalışmaya devam eder.
ELEVENLABS_API_KEY=

# --- Compose-only DB credentials (used by docker-compose.yml) -------------
POSTGRES_USER=quiz
POSTGRES_PASSWORD=quizpass
POSTGRES_DB=quiz
